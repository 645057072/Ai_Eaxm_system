# 复制为 /opt/exam-system/.env 或部署目录下 .env，由 docker compose --env-file 加载
# 公网入口（浏览器访问与 CORS）
CORS_ORIGINS=http://47.93.44.247,http://localhost,http://127.0.0.1

# JWT（生产务必改为长随机串）
SECRET_KEY=请替换为长随机字符串

# 阿里云 RDS MySQL 8.0 内网地址示例（不要在公网暴露 3306）
# DATABASE_URL=mysql+pymysql://用户:密码@rm-xxxx.mysql.rds.aliyuncs.com:3306/exam_db?charset=utf8mb4

# 若数据库仍在本机 Docker 的 mysql 服务，compose 内会注入 DATABASE_URL，无需在本文件设置。
# 切勿写 DATABASE_URL= 空值，否则会覆盖 compose 默认值并导致连接异常。

# Redis（云数据库 Redis 或本 compose 内 redis）
# REDIS_URL=redis://:密码@r-xxxx.redis.rds.aliyuncs.com:6379/0
